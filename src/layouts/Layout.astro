---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../style/global.css";

interface Props {
  title?: string;
}
const { title = "Sistema de Compra y Venta" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="bg-neutral-50 text-slate-900 min-h-screen relative font-['Plus_Jakarta_Sans',sans-serif] antialiased overflow-x-hidden selection:bg-sky-500/30 selection:text-white"
  >
    <Header />

    <slot />

    <Footer />

    <a
      href="https://api.whatsapp.com/send/?phone=%2B51949427875&text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20las%20diferentes%20lineas%20geneticas%20disponibles&type=phone_number&app_absent=0"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-4 md:bottom-10 -left-2 z-50 flex items-center justify-center w-28 h-28 md:w-40 md:h-40 transition-all duration-300 group"
      aria-label="Contactar por WhatsApp"
    >
      <div
        class="absolute inset-2 bg-[#25D366]/10 rounded-full blur-xl transition-all duration-300 group-hover:bg-[#25D366]/20 pointer-events-none"
      >
      </div>

      <span
        class="absolute inset-3 rounded-full border-2 border-[#25D366] animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite] opacity-40 pointer-events-none"
      ></span>

      <img
        src="/pollo.webp"
        alt="Asesor Chickenbaby"
        class="relative z-10 w-full h-full object-contain drop-shadow-[0_5px_15px_rgba(0,0,0,0.2)] transition-transform duration-300 group-hover:scale-120 group-hover:-translate-y-2"
      />
    </a>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
  .animate-blob {
    animation: blob 15s infinite alternate ease-in-out;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
