---

---

<div
  class="flex-1 p-8 md:p-12 lg:p-14 bg-white relative flex flex-col justify-center"
>
  <div class="mb-10">
    <h2
      class="text-slate-900 text-2xl md:text-3xl font-black font-['Nunito',sans-serif] mb-2"
    >
      Envíanos un mensaje
    </h2>
    <p class="text-slate-500 text-sm leading-relaxed">
      Completa el formulario y un asesor se comunicará contigo a la brevedad.
    </p>
  </div>

  <form id="contactForm" novalidate class="flex flex-col gap-4 relative">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="relative pb-4">
        <label
          for="nombre"
          class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
          >Nombre completo</label
        >
        <input
          type="text"
          id="nombre"
          name="nombre"
          placeholder="Ej. Juan Pérez"
          required
          class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-5 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-500/10 transition-all shadow-sm"
        />
        <span
          class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
          id="err-nombre"></span>
      </div>

      <div class="relative pb-4">
        <label
          for="telefono"
          class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
          >Teléfono / Celular</label
        >
        <input
          type="tel"
          id="telefono"
          name="telefono"
          placeholder="987 654 321"
          required
          class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-5 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-500/10 transition-all shadow-sm"
        />
        <span
          class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
          id="err-telefono"></span>
      </div>
    </div>

    <div class="relative pb-4">
      <label
        for="correo"
        class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
      >
        Correo electrónico <span
          class="normal-case tracking-normal font-normal opacity-70"
          >(opcional)</span
        >
      </label>
      <input
        type="email"
        id="correo"
        name="correo"
        placeholder="ejemplo@correo.com"
        class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-5 py-3.5 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-500/10 transition-all shadow-sm"
      />
    </div>

    <div class="relative pb-4">
      <label
        for="mensaje"
        class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
        >Tu mensaje</label
      >
      <textarea
        id="mensaje"
        name="mensaje"
        rows="4"
        required
        placeholder="Cuéntanos sobre tu volumen estimado, fechas, ubicación..."
        class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-500/10 transition-all shadow-sm resize-none"
      ></textarea>
      <span
        class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
        id="err-mensaje"></span>
    </div>

    <button
      type="submit"
      id="submitBtn"
      class="group relative w-full flex items-center justify-center gap-3 px-8 py-4 rounded-xl overflow-hidden bg-sky-500 hover:bg-sky-400 text-white font-black uppercase text-sm tracking-widest shadow-[0_8px_20px_rgba(56,189,248,0.25)] hover:shadow-[0_12px_25px_rgba(56,189,248,0.4)] hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:translate-y-0"
    >
      <span id="btnText">Enviar mensaje</span>
      <!-- Icono de Flecha -->
      <svg
        id="btnIcon"
        class="w-5 h-5 transition-transform group-hover:translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="M14 5l7 7-7 7M21 12H3"></path></svg
      >
      <!-- Icono de Spinner (Oculto por defecto) -->
      <svg
        id="btnSpinner"
        class="hidden w-5 h-5 animate-spin text-white"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        ><circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle><path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path></svg
      >
    </button>
  </form>
</div>

<!-- Componente Toast (Notificación Flotante) -->
<div
  id="toastNotification"
  class="fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-24 opacity-0 pointer-events-none"
>
  <div
    id="toastIcon"
    class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
  >
  </div>
  <div>
    <h4 id="toastTitle" class="text-sm font-bold text-slate-900"></h4>
    <p id="toastMsg" class="text-xs text-slate-500"></p>
  </div>
</div>

<script>
  const initForm = () => {
    const form = document.getElementById(
      "contactForm",
    ) as HTMLFormElement | null;
    const submitBtn = document.getElementById(
      "submitBtn",
    ) as HTMLButtonElement | null;
    const btnText = document.getElementById("btnText");
    const btnIcon = document.getElementById("btnIcon");
    const btnSpinner = document.getElementById("btnSpinner");

    const toast = document.getElementById("toastNotification");
    const toastTitle = document.getElementById("toastTitle");
    const toastMsg = document.getElementById("toastMsg");
    const toastIcon = document.getElementById("toastIcon");

    if (!form) return;

    const showToast = (
      type: "success" | "error",
      title: string,
      message: string,
    ) => {
      if (!toast || !toastTitle || !toastMsg || !toastIcon) return;

      toastTitle.textContent = title;
      toastMsg.textContent = message;

      if (type === "success") {
        toast.className =
          "fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-0 opacity-100 bg-white border border-emerald-100";
        toastIcon.className =
          "w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-emerald-100 text-emerald-500";
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>`;
      } else {
        toast.className =
          "fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-0 opacity-100 bg-white border border-rose-100";
        toastIcon.className =
          "w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-rose-100 text-rose-500";
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>`;
      }

      // Ocultar el toast después de 5 segundos
      setTimeout(() => {
        toast.classList.remove("translate-y-0", "opacity-100");
        toast.classList.add("translate-y-24", "opacity-0");
      }, 5000);
    };

    const setError = (id: string, msg: string, inputEl: HTMLElement | null) => {
      const errEl = document.getElementById(id);
      if (errEl) errEl.textContent = msg;
      if (inputEl) {
        if (msg) {
          inputEl.classList.add(
            "border-rose-500",
            "ring-4",
            "ring-rose-500/10",
          );
          inputEl.classList.remove(
            "border-slate-200",
            "focus:border-sky-500",
            "focus:ring-sky-500/10",
          );
        } else {
          inputEl.classList.remove(
            "border-rose-500",
            "ring-4",
            "ring-rose-500/10",
          );
          inputEl.classList.add(
            "border-slate-200",
            "focus:border-sky-500",
            "focus:ring-sky-500/10",
          );
        }
      }
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      let isValid = true;

      const nombre = form.querySelector<HTMLInputElement>("#nombre")!;
      const telefono = form.querySelector<HTMLInputElement>("#telefono")!;
      const correo = form.querySelector<HTMLInputElement>("#correo")!;
      const mensaje = form.querySelector<HTMLTextAreaElement>("#mensaje")!;

      // Validación simple
      if (!nombre.value.trim()) {
        setError("err-nombre", "Por favor ingresa tu nombre.", nombre);
        isValid = false;
      } else {
        setError("err-nombre", "", nombre);
      }
      if (!telefono.value.trim()) {
        setError("err-telefono", "Por favor ingresa tu teléfono.", telefono);
        isValid = false;
      } else {
        setError("err-telefono", "", telefono);
      }
      if (!mensaje.value.trim()) {
        setError("err-mensaje", "Por favor escribe tu mensaje.", mensaje);
        isValid = false;
      } else {
        setError("err-mensaje", "", mensaje);
      }

      if (!isValid) return;

      // --- INICIO DEL FETCH ---
      if (submitBtn && btnText && btnIcon && btnSpinner) {
        submitBtn.disabled = true;
        btnText.textContent = "Enviando...";
        btnIcon.classList.add("hidden");
        btnSpinner.classList.remove("hidden");
      }

      try {
        const formData = {
          nombre: nombre.value,
          telefono: telefono.value,
          correo: correo.value,
          mensaje: mensaje.value,
        };

        // REEMPLAZA ESTA URL CON EL ENDPOINT DE TU BACKEND
        const response = await fetch(
          "https://facturacion-cb-backend-production.up.railway.app/api/v1/apiPeru/contacto",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(formData),
          },
        );

        if (!response.ok) throw new Error("Error en la respuesta del servidor");

        // Éxito
        showToast(
          "success",
          "¡Mensaje enviado!",
          "Nos pondremos en contacto contigo pronto.",
        );
        form.reset();
      } catch (error) {
        console.error("Error enviando el formulario:", error);
        showToast(
          "error",
          "Error al enviar",
          "Por favor, inténtalo de nuevo más tarde.",
        );
      } finally {
        if (submitBtn && btnText && btnIcon && btnSpinner) {
          submitBtn.disabled = false;
          btnText.textContent = "Enviar mensaje";
          btnIcon.classList.remove("hidden");
          btnSpinner.classList.add("hidden");
        }
      }
    });
  };

  document.addEventListener("DOMContentLoaded", initForm);
  document.addEventListener("astro:page-load", initForm);
</script>
