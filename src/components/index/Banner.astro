---
// Banner.astro — Edición Contraste Premium
const slides = [
    {
        id: 1,
        badge: "SOMOS LÍDERES EN",
        title: "Genética de",
        highlight: "aves bebés",
        description: "Calidad garantizada en cada pollito, respaldada por procesos de selección genética de vanguardia.",
        image: "/banner/1.jpg",
        ctaText: "Empezar Ahora",
        ctaLink: "/productos",
        stat: { value: "98%", label: "Tasa de supervivencia" },
    },
    {
        id: 2,
        badge: "LA MEJOR GENÉTICA",
        title: "Aves de",
        highlight: "postura",
        description: "Asegura la productividad de tu negocio con aves diseñadas para el máximo rendimiento.",
        image: "/banner/2.jpg",
        ctaText: "Ver Catálogo",
        ctaLink: "/nosotros",
        stat: { value: "320+", label: "Huevos por año" },
    },
];
---

<section class="w-full h-screen overflow-hidden select-none bg-slate-950">
    <div id="banner-container" class="relative w-full h-full overflow-hidden group">
        
        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-slate-950/60 to-transparent z-40 pointer-events-none"></div>

        <div id="slider-track" class="flex h-full cursor-grab active:cursor-grabbing will-change-transform">
        {slides.map((slide) => (
            <div class="w-full relative h-full flex flex-col md:flex-row flex-shrink-0 overflow-hidden">

                <div class="w-full h-1/2 md:w-1/2 md:h-full order-2 md:order-1 relative z-20 flex flex-col justify-center p-8 sm:p-12 md:p-16 lg:p-24 bg-slate-950">
                    <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 via-transparent to-transparent pointer-events-none"></div>
                    
                    <div class="relative z-10 flex flex-col gap-4 md:gap-6">
                        <div class="inline-flex items-center gap-3 opacity-0 translate-y-6 [.is-visible_&]:opacity-100 [.is-visible_&]:translate-y-0 transition-all duration-1000 delay-150 ease-out">
                            <span class="w-8 h-[2px] bg-amber-500"></span>
                            <span class="text-amber-400 text-[10px] md:text-xs font-black uppercase tracking-[0.3em]">
                                {slide.badge}
                            </span>
                        </div>

                        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight text-white m-0 opacity-0 translate-y-6 [.is-visible_&]:opacity-100 [.is-visible_&]:translate-y-0 transition-all duration-1000 delay-300 ease-out">
                            {slide.title}<br />
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-amber-400 to-yellow-500">
                                {slide.highlight}
                            </span>
                        </h2>

                        <p class="text-slate-400 text-sm md:text-lg leading-relaxed max-w-[480px] opacity-0 translate-y-6 [.is-visible_&]:opacity-100 [.is-visible_&]:translate-y-0 transition-all duration-1000 delay-[450ms] ease-out">
                            {slide.description}
                        </p>

                        <div class="flex flex-wrap items-center gap-4 mt-2 md:mt-4 opacity-0 translate-y-6 [.is-visible_&]:opacity-100 [.is-visible_&]:translate-y-0 transition-all duration-1000 delay-[600ms] ease-out">
                            <div class="px-5 py-3 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md">
                                <span class="text-amber-400 text-2xl md:text-3xl font-black block leading-none">{slide.stat.value}</span>
                                <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider">{slide.stat.label}</span>
                            </div>

                            <a href={slide.ctaLink} class="px-8 py-4 rounded-2xl bg-amber-500 text-slate-950 text-xs font-black uppercase tracking-widest shadow-[0_20px_40px_-10px_rgba(245,158,11,0.5)] hover:bg-amber-400 transition-all hover:-translate-y-1 active:scale-95">
                                {slide.ctaText}
                            </a>
                        </div>
                    </div>
                </div>

                <div class="w-full h-1/2 md:w-1/2 md:h-full order-1 md:order-2 relative overflow-hidden">
                    <img
                        src={slide.image}
                        alt={slide.title}
                        class="w-full h-full object-cover object-center scale-105 group-hover:scale-110 opacity-0 [.is-visible_&]:opacity-100 transition-all duration-[2000ms] ease-out"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-slate-950 via-slate-950/20 to-transparent z-10"></div>
                </div>

            </div>
        ))}
        </div>

        <div class="absolute bottom-0 left-0 w-full h-1.5 bg-white/5 z-40">
            <div id="progress-bar" class="h-full w-0 bg-gradient-to-r from-amber-500 via-yellow-400 to-amber-300 shadow-[0_0_20px_rgba(245,158,11,0.8)]" />
        </div>
    </div>
</section>

<script>
    function initSlider() {
        const container   = document.getElementById("banner-container");
        const track       = document.getElementById("slider-track");
        const btnPrev     = document.getElementById("btn-prev");
        const btnNext     = document.getElementById("btn-next");
        const progressBar = document.getElementById("progress-bar");
        const dots        = document.querySelectorAll(".dot");

        if (!track || !progressBar || !container) return;

        // --- NUEVO: Intersection Observer para las animaciones de entrada ---
        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                // Al entrar en pantalla, agregamos la clase que detona todo
                container.classList.add("is-visible");
                observer.disconnect(); // Desconectamos para que la animación suceda solo la primera vez
            }
        }, { threshold: 0.15 }); // Se activa cuando el 15% del banner es visible

        observer.observe(container);
        // ------------------------------------------------------------------

        let currentIndex  = 0;
        const totalSlides = track.children.length;
        let timer: any;
        let dragging = false;
        let startX   = 0;

        const updateDots = () => {
            dots.forEach((d: any, i) => {
                d.style.width      = i === currentIndex ? "24px" : "12px";
                d.style.background = i === currentIndex ? "#fbbf24" : "rgba(255,255,255,0.3)";
            });
        };

        const go = (animated = true) => {
            track.style.transition = animated ? "transform 0.6s cubic-bezier(0.25, 1, 0.35, 1)" : "none";
            track.style.transform  = `translateX(-${currentIndex * 100}%)`;
            
            progressBar.style.transition = "none";
            progressBar.style.width = "0%";
            setTimeout(() => {
                progressBar.style.transition = "width 5000ms linear";
                progressBar.style.width = "100%";
            }, 50);
            
            updateDots();
        };

        const next  = () => { currentIndex = (currentIndex + 1) % totalSlides; go(); };
        const prev  = () => { currentIndex = (currentIndex - 1 + totalSlides) % totalSlides; go(); };
        const reset = () => { clearInterval(timer); timer = setInterval(next, 5000); };

        const onStart = (e: any) => {
            dragging = true;
            startX = e.type.includes("mouse") ? e.pageX : e.touches[0].pageX;
            track.style.transition = "none";
            clearInterval(timer);
        };
        const onMove = (e: any) => {
            if (!dragging) return;
            const x   = e.type.includes("mouse") ? e.pageX : e.touches[0].pageX;
            const pct = ((x - startX) / track.offsetWidth) * 100;
            track.style.transform = `translateX(calc(-${currentIndex * 100}% + ${pct}%))`;
        };
        const onEnd = (e: any) => {
            if (!dragging) return;
            dragging = false;
            const ex    = e.type.includes("mouse") ? e.pageX : e.changedTouches[0].pageX;
            const moved = ex - startX;
            if (moved < -50) next();
            else if (moved > 50) prev();
            else go();
            reset();
        };

        track.addEventListener("mousedown",  onStart);
        track.addEventListener("touchstart", onStart, { passive: true });
        window.addEventListener("mousemove", onMove);
        track.addEventListener("touchmove",  onMove,  { passive: true });
        window.addEventListener("mouseup",   onEnd);
        track.addEventListener("touchend",   onEnd);

        btnNext?.addEventListener("click", () => { next(); reset(); });
        btnPrev?.addEventListener("click", () => { prev(); reset(); });
        
        dots.forEach((d, i) => d.addEventListener("click", () => { currentIndex = i; go(); reset(); }));

        go(false);
        timer = setInterval(next, 5000);
        
        window.addEventListener("resize", () => {
            track.style.transition = "none";
            track.style.transform  = `translateX(-${currentIndex * 100}%)`;
        });
    }

    document.addEventListener("DOMContentLoaded", initSlider);
</script>