---
// Banner.astro — Hero Parallax Premium (Texto estático, Parallax solo en imagen)
const slides = [
    {
        id: 1,
        badge: "SOMOS LÍDERES EN",
        title: "Genética de",
        highlight: "aves bebés",
        description: "Calidad garantizada en cada pollito, respaldada por procesos de selección genética de vanguardia.",
        image: "/banner/1.jpg",
        ctaText: "Empezar Ahora",
        ctaLink: "/productos",
        stat: { value: "98%", label: "Tasa de supervivencia" },
    },
    {
        id: 2,
        badge: "LA MEJOR GENÉTICA",
        title: "Aves de",
        highlight: "postura",
        description: "Asegura la productividad de tu negocio con aves diseñadas para el máximo rendimiento.",
        image: "/banner/2.jpg",
        ctaText: "Ver Catálogo",
        ctaLink: "/nosotros",
        stat: { value: "320+", label: "Huevos por año" },
    },
];
---

<section class="relative w-full h-screen bg-slate-950 overflow-hidden select-none" id="hero-banner">
    
    <div id="banner-container" class="relative w-full h-full overflow-hidden group">
        
        <div id="slider-track" class="flex h-full cursor-grab active:cursor-grabbing will-change-transform">
        
        {slides.map((slide) => (
            <div class="slide-item w-full h-full relative flex-shrink-0 overflow-hidden">

                <div class="absolute inset-0 w-full h-[130%] -top-[15%] pointer-events-none overflow-hidden bg-[#07090f]">
                    <img
                        src={slide.image}
                        alt={slide.title}
                        class="parallax-bg-img w-full h-full object-cover object-center opacity-80"
                    />
                </div>

                <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-slate-950 via-slate-950/80 md:via-slate-950/60 to-transparent z-10 pointer-events-none"></div>
                
                <div class="absolute inset-0 bg-gradient-to-br from-sky-500/10 via-transparent to-amber-500/5 z-10 pointer-events-none mix-blend-overlay"></div>

                <div class="relative z-20 w-full h-full max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 flex flex-col justify-end md:justify-center pb-20 md:pb-0">
                    
                    <div class="max-w-2xl flex flex-col gap-5 md:gap-6">
                        
                        <div class="inline-flex items-center gap-3">
                            <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 backdrop-blur-md border border-white/10 text-sky-400 text-[10px] md:text-xs font-black uppercase tracking-[0.2em] shadow-[0_4px_12px_rgba(0,0,0,0.2)]">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
                                {slide.badge}
                            </span>
                        </div>

                        <h2 class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-black leading-[1.05] tracking-tighter text-white m-0 font-heading drop-shadow-lg">
                            {slide.title}<br />
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-sky-200 to-white">
                                {slide.highlight}
                            </span>
                        </h2>

                        <p class="text-slate-300/90 text-sm md:text-lg font-medium leading-relaxed max-w-[480px]">
                            {slide.description}
                        </p>

                        <div class="flex flex-wrap items-center gap-6 md:gap-8 mt-4">
                            
                            <a href={slide.ctaLink} class="group relative inline-flex items-center justify-center px-8 py-4 rounded-full overflow-hidden transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_15px_30px_rgba(14,165,233,0.2)]">
                                <div class="absolute inset-0 bg-sky-500 transition-colors duration-300 group-hover:bg-sky-400"></div>
                                <span class="relative z-10 flex items-center gap-2 text-slate-950 font-black text-xs md:text-sm uppercase tracking-widest">
                                    {slide.ctaText}
                                    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                                </span>
                            </a>

                            <div class="flex flex-col gap-0.5 border-l-2 border-slate-700 pl-5">
                                <span class="text-amber-400 text-2xl md:text-3xl font-black leading-none">{slide.stat.value}</span>
                                <span class="text-slate-400 text-[10px] md:text-xs font-bold uppercase tracking-wider">{slide.stat.label}</span>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        ))}
        </div>

        <div class="absolute bottom-0 left-0 w-full h-[3px] bg-white/10 z-40">
            <div id="progress-bar" class="h-full w-0 bg-gradient-to-r from-sky-500 via-sky-300 to-amber-400 shadow-[0_0_15px_rgba(59,165,209,0.8)]" />
        </div>
    </div>
</section>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@800;900&display=swap');
    .font-heading { font-family: 'Nunito', sans-serif; }

    /* Aceleración por hardware para el Parallax de la imagen */
    .parallax-bg-img {
        will-change: transform;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        
        const track       = document.getElementById("slider-track");
        const progressBar = document.getElementById("progress-bar");
        const section     = document.getElementById("hero-banner");

        if (!track || !progressBar || !section) return;

        // 1. LÓGICA DEL SLIDER
        let currentIndex  = 0;
        const totalSlides = track.children.length;
        let timer: any;
        let dragging = false;
        let startX   = 0;

        const go = (animated = true) => {
            track.style.transition = animated ? "transform 0.8s cubic-bezier(0.25, 1, 0.35, 1)" : "none";
            track.style.transform  = `translateX(-${currentIndex * 100}%)`;
            
            progressBar.style.transition = "none";
            progressBar.style.width = "0%";
            setTimeout(() => {
                progressBar.style.transition = "width 5000ms linear";
                progressBar.style.width = "100%";
            }, 50);
        };

        const next  = () => { currentIndex = (currentIndex + 1) % totalSlides; go(); };
        const prev  = () => { currentIndex = (currentIndex - 1 + totalSlides) % totalSlides; go(); };
        const reset = () => { clearInterval(timer); timer = setInterval(next, 5000); };

        const onStart = (e: any) => {
            dragging = true;
            startX = e.type.includes("mouse") ? e.pageX : e.touches[0].pageX;
            track.style.transition = "none";
            clearInterval(timer);
        };
        const onMove = (e: any) => {
            if (!dragging) return;
            const x   = e.type.includes("mouse") ? e.pageX : e.touches[0].pageX;
            const pct = ((x - startX) / track.offsetWidth) * 100;
            track.style.transform = `translateX(calc(-${currentIndex * 100}% + ${pct}%))`;
        };
        const onEnd = (e: any) => {
            if (!dragging) return;
            dragging = false;
            const ex    = e.type.includes("mouse") ? e.pageX : e.changedTouches[0].pageX;
            const moved = ex - startX;
            if (moved < -50) next();
            else if (moved > 50) prev();
            else go();
            reset();
        };

        track.addEventListener("mousedown",  onStart);
        track.addEventListener("touchstart", onStart, { passive: true });
        window.addEventListener("mousemove", onMove);
        track.addEventListener("touchmove",  onMove,  { passive: true });
        window.addEventListener("mouseup",   onEnd);
        track.addEventListener("touchend",   onEnd);

        go(false); // Iniciar barra de progreso
        timer = setInterval(next, 5000);
        
        window.addEventListener("resize", () => {
            track.style.transition = "none";
            track.style.transform  = `translateX(-${currentIndex * 100}%)`;
        });


        // 2. PARALLAX EXCLUSIVO PARA LA IMAGEN (Atado al Scroll)
        const parallaxImages = document.querySelectorAll('.parallax-bg-img') as NodeListOf<HTMLElement>;
        let ticking = false;

        window.addEventListener('scroll', () => {
            if (!ticking) {
                window.requestAnimationFrame(() => {
                    const scrollY = window.scrollY;
                    const sectionHeight = section.offsetHeight;

                    // Solo animamos si el banner está visible en pantalla
                    if (scrollY <= sectionHeight) {
                        // Movemos la imagen hacia abajo a una fracción de la velocidad del scroll
                        // Esto crea el efecto 3D de profundidad
                        const yOffset = scrollY * 0.4; 
                        
                        parallaxImages.forEach(img => {
                            img.style.transform = `translate3d(0, ${yOffset}px, 0)`;
                        });
                    }

                    ticking = false;
                });
                ticking = true;
            }
        }, { passive: true });
    });
</script>