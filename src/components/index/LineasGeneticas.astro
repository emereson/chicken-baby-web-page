---
// ProductsGrid.astro — Mobile Friendly Liquid Glass Overlap
const products = [
  {
    id: 1,
    title: "Gallinitas ponedoras",
    badge: "Línea mejorada",
    image: "/banner/4.jpg", 
    link: "/pedido/gallinitas",
    description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare."
  },
  {
    id: 2,
    title: "Pollitos Cobb 500",
    badge: "Alta genética",
    image: "/banner/4.jpg", 
    link: "/pedido/cobb-500",
    description: "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi."
  },
  {
    id: 3,
    title: "Pollitos Criollos",
    badge: "Resistencia",
    image: "/banner/5.jpg", 
    link: "/pedido/criollos",
    description: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident."
  },
  {
    id: 4,
    title: "Patos Pekín",
    badge: "Alta rentabilidad",
    image: "/banner/5.jpg", 
    link: "/pedido/patos",
    description: "Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi."
  }
];
---

<section class="bg-white py-24 md:py-32 overflow-hidden select-none relative" id="products-section">
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-4xl mx-auto mb-20 md:mb-24 reveal-element opacity-0 translate-y-12 transition-all duration-[1s] ease-out">
      <h2 class="text-4xl md:text-6xl lg:text-[5rem] font-black text-slate-950 tracking-tighter leading-[1.05] font-heading mb-6">
        Genética superior.<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-[#2b3275]">
          Rendimiento Pro.
        </span>
      </h2>
      <p class="text-slate-500 text-lg md:text-2xl font-medium tracking-tight max-w-2xl mx-auto">
        Diseñadas para maximizar tu rentabilidad. Cada lote es seleccionado para garantizar resultados excepcionales.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-12 md:gap-x-8 md:gap-y-20">
      
      {products.map((product, index) => {
        const isLarge = index === 0 || index === 3; 
        
        return (
          <article 
            class={`reveal-element group relative overflow-visible
            ${isLarge ? 'md:col-span-2' : 'col-span-1'} `}
            style={`transition-delay: ${index * 150}ms;`}
          >
            
            <div class={`relative w-full overflow-hidden rounded-[2.5rem] md:rounded-[3rem] shadow-2xl transition-shadow duration-[0.8s] group-hover:shadow-[0_40px_80px_rgba(43,50,117,0.15)]
              ${isLarge ? 'h-[400px] min-h-[450px]' : 'h-[400px] min-h-[400px]'}`}
            >
              <div class="absolute inset-0 w-full h-[130%] -top-[15%] parallax-img-container transition-transform duration-[1.2s] ease-[cubic-bezier(0.25,1,0.5,1)]">
                <img 
                  src={product.image} 
                  alt={product.title} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 group-hover:-rotate-1"
                />
              </div>
              
              <div class="absolute top-4 left-4 flex justify-start z-10 pointer-events-none">
                <span class="pointer-events-auto inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/30 backdrop-blur-md border border-white/20 text-white text-[10px] md:text-xs font-bold uppercase tracking-widest shadow-sm transition-colors duration-500 group-hover:bg-sky-500/80 group-hover:border-sky-300">
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                  {product.badge}
                </span>
              </div>
            </div>

            <div 
                class="pointer-events-auto relative z-20 mx-auto w-[92%] md:w-[85%] mt-[-120px] md:mt-[-120px] rounded-[2rem] md:rounded-[2.5rem] overflow-hidden transition-all duration-[0.8s] ease-[cubic-bezier(0.16,1,0.3,1)]
                bg-slate-900/45 backdrop-blur-3xl backdrop-saturate-[150%] 
                border border-white/20 shadow-[0_20px_40px_rgba(0,0,0,0.2)]
                md:group-hover:bg-slate-900/60 md:group-hover:border-white/30 md:group-hover:shadow-[0_30px_60px_rgba(0,0,0,0.3)]
                hover:-translate-y-2"
            >
                <div class="absolute -inset-20 z-0 opacity-0 blur-2xl pointer-events-none bg-gradient-to-br from-sky-400 via-transparent to-amber-400 group-hover:opacity-40 transition-opacity duration-1000"></div>

                <div class="relative z-10 p-6 md:p-6 flex flex-col justify-between">
                    <h3 class={`font-black text-white tracking-tight mb-2 leading-tight drop-shadow-md transition-colors duration-500 group-hover:text-amber-400
                      ${isLarge ? 'text-3xl md:text-5xl max-w-xl' : 'text-2xl md:text-3xl'}
                    `}>
                      {product.title}
                    </h3>
                    
                    <p class={`text-white/80 font-medium leading-relaxed drop-shadow-sm transition-colors duration-500 group-hover:text-white
                      ${isLarge ? 'text-sm md:text-base max-w-xl' : 'text-xs md:text-sm line-clamp-2 md:line-clamp-3'}
                    `}>
                      {product.description}
                    </p>
                    
                    <div class="grid grid-rows-[1fr] opacity-100 md:grid-rows-[0fr] md:opacity-0 md:group-hover:grid-rows-[1fr] md:group-hover:opacity-100 transition-all duration-[0.6s] ease-[cubic-bezier(0.16,1,0.3,1)]">
                        <div class="overflow-hidden">
                            <div class="pt-5 md:pt-6">
                                <a href={product.link} class="group/btn relative inline-flex items-center justify-center h-12 px-8 rounded-full overflow-hidden w-full md:w-auto bg-white text-slate-900 font-black text-xs md:text-sm uppercase tracking-widest transition-all duration-300 hover:scale-105 active:scale-95 shadow-lg group-hover:bg-sky-500/80 group-hover:border-sky-300">
                                    <div class="absolute inset-0 bg-gradient-to-r from-sky-400/0 via-amber-400/30 to-sky-400/0 opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>

                                    <span class="relative z-10 flex items-center gap-2 transition-colors duration-300 group-hover/btn:text-white">
                                        Realizar pedido
                                        <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
          </article>
        );
      })}

    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@800;900&display=swap');
  
  .font-heading {
    font-family: 'Nunito', sans-serif;
  }

  .parallax-img-container {
    will-change: transform;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // 1. REVEAL ANIMATION
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target instanceof HTMLElement) {
            entry.target.classList.remove('opacity-0', 'translate-y-12', 'translate-y-16');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.reveal-element').forEach(el => observer.observe(el));

    // 2. PARALLAX EFFECT
    const section = document.getElementById('products-section');
    const cards = document.querySelectorAll('article.reveal-element');

    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!section) return;

      if (!ticking) {
        window.requestAnimationFrame(() => {
          const rect = section.getBoundingClientRect();
          const viewportHeight = window.innerHeight;

          if (rect.top < viewportHeight && rect.bottom > 0) {
            cards.forEach((card) => {
              if (card instanceof HTMLElement) {
                const cardRect = card.getBoundingClientRect();
                const cardCenter = cardRect.top + (cardRect.height / 2);
                const screenCenter = viewportHeight / 2;
                const distance = (cardCenter - screenCenter) / (viewportHeight / 1.5);
                
                const imgContainer = card.querySelector('.parallax-img-container');
                if (imgContainer instanceof HTMLElement) {
                  const yOffset = Math.max(Math.min(distance * 10, 10), -10); 
                  imgContainer.style.transform = `translate3d(0, ${yOffset}%, 0)`;
                }
              }
            });
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  });
</script>