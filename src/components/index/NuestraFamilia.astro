---
// NuestraFamilia.astro — Ultra Pro FINAL (Animación premium + Stagger + Parallax smooth)
---

<section
  class="bg-white pb-24 md:pb-32 overflow-hidden relative select-none pt-0"
  id="about-section"
>
  <div class="max-w-350 mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="text-center max-w-4xl mx-auto mb-16 md:mb-20 reveal opacity-0 translate-y-10"
      data-delay="0"
    >
      <div
        class="inline-flex items-center justify-center gap-3 mb-6 reveal-child"
      >
        <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
        <h3
          class="text-sky-600 font-bold tracking-[0.2em] text-xs md:text-sm uppercase"
        >
          Nuestra Historia
        </h3>
        <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
      </div>

      <h2
        class="reveal-child text-4xl md:text-6xl lg:text-[5rem] font-black text-slate-950 tracking-tighter leading-[1.05] font-heading mb-6"
      >
        Tradición y <br class="hidden md:block" />
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-sky-500 to-[#2b3275]"
        >
          Genética de vanguardia.
        </span>
      </h2>
    </div>

    <div
      class="reveal relative w-full h-[75vh] min-h-137.5 rounded-[2.5rem] md:rounded-[3.5rem]
      overflow-hidden shadow-[0_40px_80px_rgba(43,50,117,0.1)] group
      opacity-0 translate-y-12 scale-[0.98]"
      data-delay="150"
    >
      <div class="absolute inset-0 w-full h-[130%] top-[-15%] overflow-hidden">
        <div class="parallax-img-container w-full h-full">
          <img
            src="/productos/somos_1.webp"
            alt="Familia Chickenbaby"
            class="w-full h-full object-cover transition-transform duration-[2s] ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-105"
          />
        </div>
      </div>

      <div
        class="parallax-fast absolute top-6 right-6 md:top-10 md:right-10
        bg-white/10 backdrop-blur-xl border border-white/20 text-white
        w-24 h-24 md:w-32 md:h-32 rounded-full flex flex-col items-center justify-center
        shadow-2xl transition-all duration-500 hover:scale-110 hover:bg-[#2b3275]/90 hover:border-sky-400"
      >
        <span class="text-3xl md:text-5xl font-black text-amber-400">15+</span>
        <span class="text-xs uppercase tracking-widest text-sky-100 mt-1"
          >Años</span
        >
      </div>
    </div>

    <article
      class="reveal relative z-30 mx-auto w-[92%] md:w-[80%] max-w-250
      -mt-25 md:-mt-37.5
      rounded-[2.5rem] md:rounded-[3rem] p-8 md:p-12
      opacity-0 translate-y-10 scale-[0.97]
      bg-slate-950/50 backdrop-blur-xl backdrop-saturate-180
      border border-white/10
      shadow-[0_30px_60px_rgba(0,0,0,0.3)]
      group overflow-hidden"
      data-delay="300"
    >
      <div
        class="absolute -inset-10 opacity-20 blur-3xl rounded-[3rem]
      bg-linear-to-br from-transparent via-sky-400/20 to-transparent
      group-hover:opacity-40 transition-opacity duration-700"
      >
      </div>

      <div class="relative z-10 grid md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-4">
          <h3
            class="reveal-child text-white text-3xl md:text-4xl font-black font-heading group-hover:text-sky-400 transition-colors duration-500"
          >
            Chickenbaby.
          </h3>

          <p
            class="reveal-child text-slate-300 text-sm md:text-base leading-relaxed"
          >
            Creada en el 2011 con el objetivo de atender al sector avicola
            respecto a la producción y comercialización de aves bebe, asi mismo
            durante estos años nos hemos reinventado acorde a las necesidades
            del mercado y del cliente, buscando ejercer una experiencia única
            apoyándonos en tecnología de vanguardia que nos diferencie del resto
            del mercado.
          </p>
        </div>

        <div class="my-auto flex flex-col gap-6">
          <ul class="space-y-4">
            <li class="reveal-child flex items-center gap-3">
              <div
                class="w-3.5 h-3.5 rounded-full border-[3px] border-amber-400"
              >
              </div>
              <p class="text-slate-200 text-sm">
                <strong class="text-white">Experiencia:</strong> Mas de 15 años ininterrumpidos
                en el sector avícola.
              </p>
            </li>

            <li class="reveal-child flex items-center gap-3">
              <div class="w-3.5 h-3.5 rounded-full border-[3px] border-sky-500">
              </div>
              <p class="text-slate-300 text-sm">
                <strong class="text-white">Equipo Humano:</strong>Profesionales
                de primer nivel al servicio de cualquier requerimiento.
              </p>
            </li>
          </ul>

          <a
            href="/nosotros"
            class="reveal-child group/btn relative inline-flex items-center justify-center px-10 py-4 rounded-full overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-white group-hover/btn:bg-sky-500 transition-colors duration-300"
            >
            </div>

            <span
              class="relative z-10 flex items-center text-slate-950 font-bold group-hover/btn:text-white transition-colors"
            >
              Conoce más
              <svg
                class="w-5 h-5 ml-2 transition-transform group-hover/btn:translate-x-1"
                fill="none"
                stroke="currentColor"
              >
                <path stroke-width="2.5" d="M14 5l7 7-7 7M21 12H3"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .font-heading {
    font-family: "Nunito", sans-serif;
  }

  /* Animación base */
  .reveal {
    will-change: transform, opacity;
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Stagger hijos */
  .reveal-child {
    opacity: 0;
    transform: translateY(12px);
    transition: all 0.6s ease;
  }

  /* Parallax suave */
  .parallax-img-container,
  .parallax-fast {
    will-change: transform;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          // FIX: Convertimos el string del dataset a número para evitar el error TS2345
          const delay = parseInt(el.dataset.delay || "0", 10);

          setTimeout(() => {
            el.classList.remove(
              "opacity-0",
              "translate-y-10",
              "translate-y-12",
              "scale-[0.97]",
              "scale-[0.98]",
            );
            el.classList.add("opacity-100", "translate-y-0", "scale-100");

            // FIX: Declaramos que los hijos son HTMLElement para evitar el error TS2339 en .style
            const children = el.querySelectorAll<HTMLElement>(".reveal-child");
            children.forEach((child, i) => {
              setTimeout(() => {
                child.style.opacity = "1";
                child.style.transform = "translateY(0)";
              }, i * 120);
            });
          }, delay);

          obs.unobserve(el);
        });
      },
      { threshold: 0.15 },
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    // PARALLAX
    const section = document.getElementById("about-section");
    // FIX: Casteamos a HTMLElement explícitamente
    const img = document.querySelector(
      ".parallax-img-container",
    ) as HTMLElement | null;
    const fast = document.querySelector(".parallax-fast") as HTMLElement | null;

    let ticking = false;

    window.addEventListener(
      "scroll",
      () => {
        if (!section) return;

        if (!ticking) {
          requestAnimationFrame(() => {
            const rect = section.getBoundingClientRect();
            const vh = window.innerHeight;

            if (rect.top < vh && rect.bottom > 0) {
              const center = rect.top + rect.height / 2;
              const distance = (center - vh / 2) / (vh / 1.5);

              if (img)
                img.style.transform = `translate3d(0, ${distance * 10}%, 0)`;
              if (fast)
                fast.style.transform = `translate3d(0, ${-distance * 50}px, 0)`;
            }

            ticking = false;
          });

          ticking = true;
        }
      },
      { passive: true },
    );
  });
</script>
