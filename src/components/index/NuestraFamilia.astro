---
// NuestraFamilia.astro — Nivel Ultra Pro (Dark Liquid Glass Overlap)
---

<section class="bg-white pb-24 md:pb-32 overflow-hidden relative select-none pt-0" id="about-section">
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-4xl mx-auto mb-16 md:mb-20 reveal-text opacity-0 translate-y-12 transition-all duration-[1s] ease-out">
      <div class="inline-flex items-center justify-center gap-3 mb-6">
        <span class="w-8 h-[2px] bg-sky-500 rounded-full"></span>
        <h3 class="text-sky-600 font-bold tracking-[0.2em] text-xs md:text-sm uppercase">
          Nuestra Historia
        </h3>
        <span class="w-8 h-[2px] bg-sky-500 rounded-full"></span>
      </div>
      
      <h2 class="text-4xl md:text-6xl lg:text-[5rem] font-black text-slate-950 tracking-tighter leading-[1.05] font-heading mb-6">
        Tradición y <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-[#2b3275]">
          Genética de vanguardia.
        </span>
      </h2>
    </div>

    <div class="reveal-panel relative w-full h-[75vh] min-h-[550px] rounded-[2.5rem] md:rounded-[3.5rem] overflow-hidden shadow-[0_40px_80px_rgba(43,50,117,0.1)] group opacity-0 translate-y-16 transition-all duration-[1.2s] ease-out delay-200">
      
      <div class="absolute inset-0 w-full h-[130%] -top-[15%] overflow-hidden">
        <div class="parallax-img-container w-full h-full transform transition-transform duration-[0.8s] ease-out">
          <img 
            src="/banner/6.jpg" 
            alt="Familia Chickenbaby" 
            class="w-full h-full object-cover transition-transform duration-[2s] ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-105"
          />
        </div>
      </div>

      <div class="absolute top-6 right-6 md:top-10 md:right-10 bg-white/10 backdrop-blur-xl border border-white/20 text-white w-24 h-24 md:w-32 md:h-32 rounded-full flex flex-col items-center justify-center shadow-2xl z-30 transition-transform duration-500 hover:scale-110 hover:bg-[#2b3275]/90 hover:border-sky-400 cursor-default parallax-fast">
        <span class="text-3xl md:text-5xl font-black leading-none font-heading text-amber-400 drop-shadow-md">16+</span>
        <span class="text-[9px] md:text-xs font-bold uppercase tracking-widest text-sky-100 mt-1 md:mt-2">Años</span>
      </div>

    </div>

    <article 
        class="relative z-30 mx-auto w-[92%] md:w-[80%] max-w-[1000px] mt-[-100px] md:mt-[-150px] rounded-[2.5rem] md:rounded-[3rem] p-8 md:p-12 opacity-0 translate-y-12 transition-all duration-[1s] ease-[cubic-bezier(0.16,1,0.3,1)] delay-500 reveal-inner parallax-slow group overflow-hidden
        bg-slate-950/50 backdrop-blur-xl backdrop-saturate-[180%] 
        border border-white/10
        shadow-[0_30px_60px_rgba(0,0,0,0.3)]
        hover:border-white/20 hover:shadow-[0_40px_80px_rgba(14,165,233,0.15)] transition-all duration-500"
    >
        <div class="absolute -inset-10 z-0 opacity-20 blur-3xl pointer-events-none rounded-[3rem] bg-gradient-to-br from-transparent via-sky-400/20 to-transparent group-hover:opacity-40 transition-opacity duration-700"></div>

        <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-start">
            
            <div>
                <h3 class="text-white text-3xl md:text-4xl font-black font-heading tracking-tight mb-4 group-hover:text-sky-400 transition-colors duration-500">
                    Chickenbaby.
                </h3>
                <p class="text-slate-300 text-sm md:text-base font-medium max-w-xl leading-relaxed">
                    Creada en 2007 con mucho esfuerzo y dedicación. Crecemos gracias al empeño en ofrecer siempre las mejores aves bebes del mercado. Para nosotros, cada cliente es especial.
                </p>
            </div>

            <div class="flex flex-col">
                <ul class="space-y-4 mb-8 md:mb-10 w-full max-w-md">
                    <li class="relative group/item flex items-center gap-3">
                        <div class="w-3.5 h-3.5 rounded-full bg-slate-900 border-[3px] border-amber-400 shrink-0 transition-transform duration-300 group-hover/item:scale-125"></div>
                        <p class="text-slate-300 text-xs md:text-sm group-hover:text-white transition-colors duration-300">
                            <strong class="text-white">Amplia Experiencia:</strong> Producción de Cobb 500, criollos, pavos y ponedoras.
                        </p>
                    </li>
                    <li class="relative group/item flex items-center gap-3">
                        <div class="w-3.5 h-3.5 rounded-full bg-slate-900 border-[3px] border-sky-500 shrink-0 transition-transform duration-300 group-hover/item:scale-125"></div>
                        <p class="text-slate-300 text-xs md:text-sm group-hover:text-white transition-colors duration-300">
                            <strong class="text-white">Asesoramiento Permanente:</strong> Acompañamiento por especialistas técnicos capacitados.
                        </p>
                    </li>
                </ul>

                <div class="w-full">
                    <a href="/detalles" class="group/btn relative inline-flex items-center justify-center w-full md:w-auto px-10 py-4 rounded-full transition-all duration-300 hover:scale-105 active:scale-95 uppercase tracking-widest overflow-hidden shadow-lg shadow-black/20">
                        
                        <div class="absolute inset-0 bg-white transition-colors duration-300 group-hover/btn:bg-sky-500"></div>

                        <span class="relative text-sm z-10 flex items-center text-slate-950 font-black tracking-wide group-hover/btn:text-white transition-colors duration-300">
                            Conoce nuestra historia
                            <svg class="w-5 h-5 ml-2 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                </div>
            </div>
        </div>

    </article>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@800;900&display=swap');
  
  .font-heading {
    font-family: 'Nunito', sans-serif;
  }

  /* Optimización GPU */
  .parallax-img-container, .parallax-fast, .parallax-slow {
    will-change: transform;
    transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // 1. REVEAL ANIMATION
    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains('reveal-text')) {
             const el = entry.target as HTMLElement;
             el.classList.remove('opacity-0', 'translate-y-12');
             el.classList.add('opacity-100', 'translate-y-0');
             observer.unobserve(el);
          }
          if (entry.target.classList.contains('reveal-panel')) {
             const panel = entry.target as HTMLElement;
             panel.classList.remove('opacity-0', 'translate-y-16');
             panel.classList.add('opacity-100', 'translate-y-0');
             observer.unobserve(panel);
          }
          if (entry.target.classList.contains('reveal-inner')) {
             setTimeout(() => {
                const inner = entry.target as HTMLElement;
                inner.classList.remove('opacity-0', 'translate-y-12');
                inner.classList.add('opacity-100', 'translate-y-0');
                observer.unobserve(inner);
             }, 300);
          }
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.reveal-text, .reveal-panel, .reveal-inner').forEach(el => observer.observe(el));

    // 2. PARALLAX EFFECT 3D
    const section = document.getElementById('about-section');
    const parallaxImg = document.querySelector('.parallax-img-container') as HTMLElement | null;
    const parallaxFast = document.querySelector('.parallax-fast') as HTMLElement | null;
    const parallaxSlow = document.querySelector('.parallax-slow') as HTMLElement | null;

    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!section) return;
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const rect = section.getBoundingClientRect();
          const viewportHeight = window.innerHeight;
          if (rect.top < viewportHeight && rect.bottom > 0) {
            const sectionCenter = rect.top + (rect.height / 2);
            const screenCenter = viewportHeight / 2;
            const distance = (sectionCenter - screenCenter) / (viewportHeight / 1.5);
            
            if (parallaxImg) {
              const yOffset = Math.max(Math.min(distance * 12, 12), -12);
              parallaxImg.style.transform = `translate3d(0, ${yOffset}%, 0)`;
            }
            if (parallaxFast && window.innerWidth > 768) {
               const yOffset = -(distance * 60); 
               parallaxFast.style.transform = `translate3d(0, ${yOffset}px, 0)`;
            }
            if (parallaxSlow && window.innerWidth > 768) {
               const yOffset = -(distance * 25); 
               parallaxSlow.style.transform = `translate3d(0, ${yOffset}px, 0)`;
            }
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  });
</script>