---
// Footer.astro - Dark Mode Premium (Liquid Glass & Bento Style)
const currentYear = new Date().getFullYear();

const links = {
  empresa: [
    { name: 'Inicio', href: '/' },
    { name: 'Nosotros', href: '/nosotros' },
    { name: 'Galería', href: '/galeria' },
  ],
  productos: [
    { name: 'Gallinitas Ponedoras', href: '/pedido/gallinitas' },
    { name: 'Pollitos Cobb 500', href: '/pedido/cobb-500' },
    { name: 'Pollitos Criollos', href: '/pedido/criollos' },
    { name: 'Patos Pekín', href: '/pedido/patos' },
  ],
  contacto: [
    { name: 'WhatsApp', href: 'https://wa.me/51900000000', icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-4.821 8.303c-1.806 0-3.578-.484-5.127-1.402l-.368-.218-3.814.999 1.017-3.717-.239-.381C2.464 16.452 1.85 14.28 1.85 12.015 1.85 6.4 6.435 1.815 12.045 1.815c2.715 0 5.268 1.057 7.185 2.977 1.918 1.919 2.974 4.472 2.974 7.189-.001 5.615-4.586 10.202-10.202 10.202' },
    { name: 'ventas@chickenbaby.com', href: 'mailto:ventas@chickenbaby.com', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
  ]
};
---

<footer class="relative bg-slate-950 pt-12 pb-12 overflow-hidden select-none">
  
  <div class="max-w-6xl mx-auto px-4 mb-20 relative z-10 ">
    <div class="reveal-element opacity-0 translate-y-12 transition-all duration-1000 relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-sky-500 to-amber-500 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
      
      <div class="relative bg-slate-900/50 backdrop-blur-2xl border border-white/10 p-8 md:p-12 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xl">
        <div class="max-w-xl text-center md:text-left">
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tighter">¿Listo para mejorar tu producción?</h2>
          <p class="text-slate-400 font-medium leading-relaxed">Únete a cientos de productores que confían en nuestra genética superior. Calidad garantizada en cada entrega.</p>
        </div>
        <a href="/contacto" class="group/btn relative inline-flex items-center justify-center px-10 py-4 rounded-full bg-sky-500 text-slate-950 font-black text-sm uppercase tracking-widest transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_10px_20px_rgba(14,165,233,0.3)]">
          <span class="relative z-10 flex items-center gap-2 group-hover/btn:text-white transition-colors duration-300">
            Contactar Ahora
            <svg class="w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </span>
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="reveal-element opacity-0 translate-y-8 transition-all duration-700 delay-100">
        <img src="/logo2.png" alt="Chickenbaby Logo" class="h-10 w-auto mb-6 brightness-110" />
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          Líderes en genética avícola desde 2007. Comprometidos con la excelencia, la tecnología y el éxito de cada productor.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-sky-400 hover:bg-sky-400/10 hover:border-sky-400/30 transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-sky-400 hover:bg-sky-400/10 hover:border-sky-400/30 transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <div class="reveal-element opacity-0 translate-y-8 transition-all duration-700 delay-200 lg:pl-10">
        <h4 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-sky-500"></span>
          Empresa
        </h4>
        <ul class="space-y-4">
          {links.empresa.map(link => (
            <li><a href={link.href} class="text-slate-400 text-sm hover:text-sky-400 transition-colors flex items-center gap-2 group">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-800 group-hover:bg-sky-500 transition-colors"></span>
              {link.name}
            </a></li>
          ))}
        </ul>
      </div>

      <div class="reveal-element opacity-0 translate-y-8 transition-all duration-700 delay-300">
        <h4 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-sky-500"></span>
          Nuestras Líneas
        </h4>
        <ul class="space-y-4">
          {links.productos.map(link => (
            <li><a href={link.href} class="text-slate-400 text-sm hover:text-sky-400 transition-colors flex items-center gap-2 group">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-800 group-hover:bg-sky-500 transition-colors"></span>
              {link.name}
            </a></li>
          ))}
        </ul>
      </div>

      <div class="reveal-element opacity-0 translate-y-8 transition-all duration-700 delay-400">
        <h4 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-sky-500"></span>
          Atención al Cliente
        </h4>
        <ul class="space-y-5">
          {links.contacto.map(item => (
            <li>
              <a href={item.href} class="flex items-start gap-3 group text-slate-400 hover:text-white transition-colors">
                <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:bg-sky-500/20 group-hover:border-sky-500/50 group-hover:text-sky-400 transition-all duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
                </div>
                <span class="text-sm font-medium pt-1.5 leading-tight">{item.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-slate-500 text-xs font-medium">
        &copy; {currentYear} Avícola Chicken Baby. Todos los derechos reservados.
      </p>
      <div class="flex gap-8">
        <a href="#" class="text-slate-500 text-xs hover:text-sky-400 transition-colors">Términos y Condiciones</a>
        <a href="#" class="text-slate-500 text-xs hover:text-sky-400 transition-colors">Políticas de Privacidad</a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-sky-500/5 rounded-full blur-[120px] pointer-events-none translate-x-1/2 translate-y-1/2"></div>
</footer>

<style>
  /* Mantenemos la consistencia con la tipografía */
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@800;900&display=swap');
  h2, h4 { font-family: 'Nunito', sans-serif; }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target instanceof HTMLElement) {
            entry.target.classList.remove('opacity-0', 'translate-y-12', 'translate-y-8');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-element').forEach(el => observer.observe(el));
  });
</script>