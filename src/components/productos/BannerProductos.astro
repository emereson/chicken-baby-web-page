---
// BannerProductos.astro — Static Hero Parallax (Liquid Glass Pro)
---

<section
  class="relative w-full h-[65vh] min-h-[500px] bg-slate-950 overflow-hidden select-none"
  id="productos-banner"
>
  <div
    class="absolute inset-0 w-full h-[130%] -top-[15%] pointer-events-none overflow-hidden bg-slate-950"
  >
    <img
      src="/banner/4.webp"
      alt="Catálogo de Aves Chickenbaby"
      loading="eager"
      class="parallax-bg-img w-full h-full object-cover object-center opacity-0 scale-105 [.is-loaded_&]:opacity-70 [.is-loaded_&]:scale-100 transition-all duration-[2s] ease-[cubic-bezier(0.16,1,0.3,1)]"
    />
  </div>

  <div
    class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-transparent to-slate-950/90 z-10 pointer-events-none"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-br from-sky-500/10 via-transparent to-amber-500/10 z-10 pointer-events-none mix-blend-overlay"
  >
  </div>

  <div
    class="relative z-20 w-full h-full flex items-center justify-center px-4 sm:px-6 mt-10"
  >
    <div
      id="banner-content"
      class="relative group max-w-4xl w-full p-8 md:p-14 rounded-[3rem] text-center overflow-hidden opacity-0 translate-y-12 [.is-loaded_&]:opacity-100 [.is-loaded_&]:translate-y-0 transition-all duration-[1s] ease-[cubic-bezier(0.16,1,0.3,1)] delay-200
            bg-slate-900/40 backdrop-blur-3xl backdrop-saturate-[150%]
            border border-white/10 shadow-[0_30px_60px_rgba(0,0,0,0.5)]"
    >
      <div
        class="absolute -inset-20 z-0 opacity-30 blur-3xl pointer-events-none rounded-[3rem] bg-gradient-to-b from-sky-400/20 via-transparent to-amber-400/10 group-hover:opacity-50 transition-opacity duration-1000"
      >
      </div>

      <div class="relative z-10 flex flex-col items-center gap-6">
        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 backdrop-blur-md border border-white/10 text-sky-400 text-[10px] md:text-xs font-black uppercase tracking-[0.2em] shadow-[0_4px_12px_rgba(0,0,0,0.2)]"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"
          ></span>
          Catálogo Premium
        </div>

        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tighter text-white m-0 font-heading drop-shadow-md"
        >
          Nuestras líneas de <br class="hidden sm:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-sky-200 to-white"
          >
            alto rendimiento.
          </span>
        </h1>

        <p
          class="text-slate-300 text-sm md:text-lg font-medium leading-relaxed max-w-2xl mx-auto drop-shadow-sm"
        >
          Descubre nuestra selección de aves bebes diseñadas para maximizar la
          rentabilidad de tu negocio, con los más altos estándares genéticos y
          sanitarios.
        </p>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-sky-500/50 to-transparent z-30"
  >
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Nunito:wght@800;900&display=swap");

  .font-heading {
    font-family: "Nunito", sans-serif;
  }

  .parallax-bg-img {
    will-change: transform;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Escuchamos el ID específico de productos
    const section = document.getElementById("productos-banner");
    if (!section) return;

    // 1. ANIMACIÓN DE CARGA INICIAL
    setTimeout(() => {
      section.classList.add("is-loaded");
    }, 100);

    // 2. PARALLAX EXCLUSIVO PARA LA IMAGEN Y TARJETA
    const parallaxImages = document.querySelectorAll(
      ".parallax-bg-img",
    ) as NodeListOf<HTMLElement>;
    const bannerContent = document.getElementById(
      "banner-content",
    ) as HTMLElement | null;

    let ticking = false;

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const sectionHeight = section.offsetHeight;

            if (scrollY <= sectionHeight) {
              // Parallax de la imagen
              const imgOffset = scrollY * 0.4;
              parallaxImages.forEach((img) => {
                img.style.transform = `translate3d(0, ${imgOffset}px, 0)`;
              });

              // Parallax inverso suave de la tarjeta
              if (bannerContent) {
                const cardOffset = -(scrollY * 0.15);
                bannerContent.style.transform = `translate3d(0, ${cardOffset}px, 0)`;
              }
            }

            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );
  });
</script>
