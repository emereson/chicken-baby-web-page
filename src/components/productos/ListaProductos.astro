<style>
  .font-heading {
    font-family: "Nunito", sans-serif;
  }

  .reveal {
    will-change: transform, opacity;
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-child {
    opacity: 0;
    transform: translateY(12px);
    transition: all 0.6s ease;
  }

  .parallax-element,
  .parallax-img-container {
    will-change: transform;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || "0", 10);

          setTimeout(() => {
            el.classList.remove("opacity-0", "translate-y-12");
            el.classList.add("opacity-100", "translate-y-0");

            const children = el.querySelectorAll<HTMLElement>(".reveal-child");
            children.forEach((child, i) => {
              setTimeout(() => {
                child.style.opacity = "1";
                child.style.transform = "translateY(0)";
              }, i * 100);
            });
          }, delay);

          obs.unobserve(el);
        });
      },
      { threshold: 0.1 },
    );

    const section = document.getElementById("lista-productos");
    if (section) {
      section.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    }

    const parallaxElements =
      document.querySelectorAll<HTMLElement>(".parallax-element");
    const imgContainers = document.querySelectorAll<HTMLElement>(
      ".parallax-img-container",
    );

    let ticking = false;

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const vh = window.innerHeight;

            parallaxElements.forEach((el) => {
              const rect = el.getBoundingClientRect();
              if (rect.top < vh && rect.bottom > 0) {
                const center = rect.top + rect.height / 2;
                const distance = center - vh / 2;
                const speed = parseFloat(el.dataset.speed || "0");
                const yOffset = distance * speed;
                el.style.transform = `translate3d(0, ${yOffset}px, 0)`;
              }
            });

            imgContainers.forEach((container) => {
              const rect = container.getBoundingClientRect();
              if (rect.top < vh && rect.bottom > 0) {
                const center = rect.top + rect.height / 2;
                const distance = (center - vh / 2) / (vh / 1.5);
                const img = container.querySelector("img");
                if (img) {
                  const yOffset = Math.max(Math.min(distance * 8, 8), -8);
                  img.style.transform = `translate3d(0, ${yOffset}%, 0)`;
                }
              }
            });

            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );
  });
</script>
