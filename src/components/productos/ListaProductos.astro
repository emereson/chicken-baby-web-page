                  <h3 class="text-slate-900 text-2xl md:text-3xl font-black font-heading mb-3 group-hover:text-sky-500 transition-colors">
                    {producto.title}
                  </h3>
                  <p class="text-slate-500 text-sm md:text-base leading-relaxed mb-6 flex-grow">
