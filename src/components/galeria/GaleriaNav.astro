---
/*
  GaleriaNav.astro — Galería interactiva (Tailwind Puro)
  Mejoras: Scroll móvil nativo arreglado, 95% del CSS eliminado usando Tailwind Data Attributes (data-[active=true]).
*/

const galerias = [
  {
    id: "aves",
    title: "Nuestras Aves",
    description:
      "Explora la vitalidad, salud y excelente desarrollo de nuestras líneas genéticas en sus primeras etapas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="6.5"></line></svg>`,
    images: [
      "/banner/1.webp",
      "/banner/2.webp",
      "/banner/3.webp",
      "/banner/4.webp",
      "/banner/5.webp",
    ],
  },
  {
    id: "instalaciones",
    title: "Instalaciones",
    description:
      "Infraestructura de vanguardia y bioseguridad diseñada para máxima eficiencia.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path></svg>`,
    images: [
      "/banner/2.webp",
      "/banner/3.webp",
      "/banner/4.webp",
      "/banner/1.webp",
    ],
  },
  {
    id: "flota",
    title: "Nuestra Flota",
    description:
      "Vehículos climatizados para entregas puntuales y bienestar animal.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>`,
    images: ["/banner/3.webp", "/banner/4.webp", "/banner/5.webp"],
  },
  {
    id: "equipo",
    title: "Nuestro Equipo",
    description:
      "Profesionales apasionados comprometidos con la excelencia avícola.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
    images: ["/banner/6.webp", "/banner/7.webp", "/banner/8.webp"],
  },
];
---

<section
  id="galeria-interactiva"
  class="relative overflow-hidden py-24 md:py-32 bg-slate-50"
>
  <div class="relative z-10 max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="text-center max-w-4xl mx-auto mb-12 md:mb-20 js-reveal opacity-0 translate-y-12 transition-all duration-[800ms] ease-out data-[reveal=true]:opacity-100 data-[reveal=true]:translate-y-0"
      data-delay="0"
    >
      <div
        class="inline-flex items-center justify-center gap-3 mb-6 js-reveal-child opacity-0 translate-y-4 transition-all duration-500 data-[reveal=true]:opacity-100 data-[reveal=true]:translate-y-0"
      >
        <span class="w-8 h-[2px] bg-amber-400 rounded-full"></span>
        <h3
          class="text-amber-500 font-bold tracking-[0.2em] text-xs md:text-sm uppercase"
        >
          Nuestra Galería
        </h3>
        <span class="w-8 h-[2px] bg-amber-400 rounded-full"></span>
      </div>
      <h2
        class="js-reveal-child opacity-0 translate-y-4 transition-all duration-700 delay-100 data-[reveal=true]:opacity-100 data-[reveal=true]:translate-y-0 text-4xl md:text-6xl lg:text-[5rem] font-black text-slate-900 tracking-tighter leading-[1.05] font-heading"
      >
        Un vistazo a nuestra <br class="hidden md:block" />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 via-sky-400 to-amber-400"
        >
          excelencia avícola.
        </span>
      </h2>
    </div>

    <div
      class="js-reveal opacity-0 translate-y-12 transition-all duration-[800ms] ease-out data-[reveal=true]:opacity-100 data-[reveal=true]:translate-y-0 w-full"
      data-delay="150"
    >
      <div
        class="w-full overflow-x-auto pb-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden snap-x snap-mandatory"
      >
        <div class="flex md:justify-center w-max min-w-full px-4 md:px-0">
          <div
            role="tablist"
            aria-label="Galería de imágenes"
            class="flex-none inline-flex items-center gap-1.5 md:gap-2 p-1.5 md:p-2 rounded-full bg-slate-600/60 backdrop-blur-md border border-white/15 shadow-[0_4px_20px_-2px_rgba(15,23,42,0.15)]"
          >
            {
              galerias.map((item, i) => (
                <button
                  role="tab"
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-controls={`panel-${item.id}`}
                  id={`tab-${item.id}`}
                  data-target={item.id}
                  data-active={i === 0 ? "true" : "false"}
                  class="galeria-tab group flex-none inline-flex items-center gap-1.5 md:gap-2 px-4 py-2 md:px-6 md:py-2.5 rounded-full text-slate-100 bg-transparent font-bold text-xs md:text-sm uppercase whitespace-nowrap cursor-pointer transition-all duration-400 ease-out hover:bg-white/10 hover:text-white data-[active=true]:text-amber-400 data-[active=true]:bg-slate-900 data-[active=true]:shadow-[0_8px_20px_-4px_rgba(15,23,42,0.5),inset_0_1px_1px_rgba(255,255,255,0.1)] data-[active=true]:-translate-y-0.5 snap-center"
                >
                  <div
                    class="flex items-center justify-center w-4 h-4 opacity-70 transition-all duration-300 group-hover:scale-110 group-hover:opacity-100 group-data-[active=true]:opacity-100 group-data-[active=true]:drop-shadow-[0_0_6px_rgba(251,191,36,0.6)]"
                    set:html={item.icon}
                  />
                  <span>{item.title}</span>
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div
      class="js-reveal opacity-0 translate-y-12 transition-all duration-800 ease-out data-[reveal=true]:opacity-100 data-[reveal=true]:translate-y-0 relative z-30 max-w-[1400px] mx-auto w-full mb-10 md:mb-10"
      data-delay="250"
    >
      <div
        class="relative w-full max-w-[1400px] mx-auto bg-slate-900/85 backdrop-blur-lg border border-white/10 rounded-[20px] md:rounded-[24px] px-5 py-4 md:px-8 md:py-6 shadow-[0_12px_32px_-4px_rgba(15,23,42,0.3)] overflow-hidden before:absolute before:inset-y-0 before:left-0 before:w-1 before:bg-amber-400 before:shadow-[0_0_15px_2px_rgba(251,191,36,0.5)] before:z-10"
      >
        <div class="relative w-full min-h-18">
          {
            galerias.map((item, i) => (
              <div
                id={`desc-${item.id}`}
                data-active={i === 0 ? "true" : "false"}
                class="galeria-desc absolute inset-0 w-full flex items-center md:items-start gap-4 md:gap-5 opacity-0 translate-y-4 z-0 pointer-events-none transition-all duration-500 ease-in-out data-[active=true]:opacity-100 data-[active=true]:translate-y-0 data-[active=true]:z-10 data-[active=true]:pointer-events-auto"
              >
                <div class="flex items-center justify-center shrink-0 w-10 h-10 md:w-12 md:h-12 bg-amber-400/10 border border-amber-400/20 rounded-full text-amber-400">
                  <div class="w-5 h-5 md:w-6 md:h-6" set:html={item.icon} />
                </div>
                <div>
                  <h4 class="text-white font-bold text-lg mb-1 hidden md:block">
                    {item.title}
                  </h4>
                  <p class="text-slate-300 text-sm md:text-base leading-relaxed font-medium">
                    {item.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="relative z-10 mt-8 max-w-[1400px] mx-auto w-full">
      {
        galerias.map((galeria, gi) => (
          <div
            role="tabpanel"
            id={`grid-${galeria.id}`}
            aria-labelledby={`tab-${galeria.id}`}
            data-active={gi === 0 ? "true" : "false"}
            class="galeria-grid absolute inset-0 w-full grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-3 md:gap-4 auto-rows-[140px] sm:auto-rows-[180px] md:auto-rows-[240px] xl:auto-rows-[280px] opacity-0 z-0 pointer-events-none translate-y-8 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] data-[active=true]:opacity-100 data-[active=true]:relative data-[active=true]:z-20 data-[active=true]:pointer-events-auto data-[active=true]:translate-y-0"
          >
            {galeria.images.map((img, i) => {
              let span = "col-span-1 row-span-1";
              if (i === 0) span = "col-span-2 row-span-2";
              else if (i === 3 && galeria.images.length > 4)
                span = "col-span-2 row-span-1";

              return (
                <div
                  data-index={i}
                  data-visible="false"
                  class={`gallery-item relative overflow-hidden rounded-2xl md:rounded-[24px] bg-slate-100 border border-slate-200 cursor-default opacity-0 translate-y-4 scale-[0.98] transition-all duration-600 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1.5 hover:shadow-[0_20px_40px_-10px_rgba(14,165,233,0.18),0_4px_12px_-2px_rgba(251,191,36,0.12)] hover:border-sky-200 hover:z-30 group data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0 data-[visible=true]:scale-100 ${span}`}
                  style={`transition-delay: ${i * 70}ms;`}
                >
                  <img
                    src={img}
                    alt={`${galeria.title} - Imagen ${i + 1}`}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover scale-[1.03] transition-transform duration-[1.6s] ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-[1.09]"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent opacity-0 transition-opacity duration-300 pointer-events-none group-hover:opacity-100" />
                </div>
              );
            })}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap");
  .font-heading {
    font-family: "Nunito", sans-serif;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. ANIMACIÓN DE ENTRADA CON DATA ATTRIBUTES
    const revealObs = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay ?? "0", 10);

          setTimeout(() => {
            el.dataset.reveal = "true";
            el.querySelectorAll<HTMLElement>(".js-reveal-child").forEach(
              (c) => {
                c.dataset.reveal = "true";
              },
            );
          }, delay);
          obs.unobserve(el);
        });
      },
      { threshold: 0.1 },
    );

    document
      .querySelectorAll(".js-reveal")
      .forEach((el) => revealObs.observe(el));

    // 2. LÓGICA DE TABS USANDO DATA ATTRIBUTES (data-active y data-visible)
    const tabs = document.querySelectorAll<HTMLElement>(".galeria-tab");
    const grids = document.querySelectorAll<HTMLElement>(".galeria-grid");
    const descs = document.querySelectorAll<HTMLElement>(".galeria-desc");

    const triggerGridCascade = (gridId: string) => {
      const grid = document.getElementById(gridId);
      if (!grid) return;
      grid.querySelectorAll<HTMLElement>(".gallery-item").forEach((item) => {
        item.dataset.visible = "false";
        void item.offsetWidth; // Forzar repintado del DOM
        item.dataset.visible = "true";
      });
    };

    // Iniciar el primer grid
    setTimeout(() => triggerGridCascade("grid-aves"), 450);

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        if (tab.dataset.active === "true") return;

        const targetId = tab.dataset.target ?? "";

        // Centrar el tab activo en la vista si está en móvil
        tab.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "center",
        });

        // Actualizar tabs
        tabs.forEach((t) => {
          const isActive = t === tab;
          t.dataset.active = isActive ? "true" : "false";
          t.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        // Actualizar descripciones
        descs.forEach((desc) => {
          desc.dataset.active =
            desc.id === `desc-${targetId}` ? "true" : "false";
        });

        // Actualizar grids e items
        grids.forEach((grid) => {
          const isTargetGrid = grid.id === `grid-${targetId}`;
          grid.dataset.active = isTargetGrid ? "true" : "false";

          if (isTargetGrid) {
            triggerGridCascade(grid.id);
          } else {
            grid
              .querySelectorAll<HTMLElement>(".gallery-item")
              .forEach((item) => {
                item.dataset.visible = "false";
              });
          }
        });
      });
    });
  });
</script>
