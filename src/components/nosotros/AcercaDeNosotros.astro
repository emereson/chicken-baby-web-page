---
// AcercaDeNosotros.astro — Ultra Pro FINAL (Misión, Visión & Staggered Reveal)
---

<section
  class="bg-white py-24 md:pb-32 overflow-hidden relative select-none"
  id="acerca-section"
>
  <div class="max-w-350 mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="text-center max-w-4xl mx-auto mb-16 md:mb-20 reveal opacity-0 translate-y-10"
      data-delay="0"
    >
      <div
        class="inline-flex items-center justify-center gap-3 mb-6 reveal-child"
      >
        <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
        <h3
          class="text-sky-600 font-bold tracking-[0.2em] text-xs md:text-sm uppercase"
        >
          Nuestra Esencia
        </h3>
        <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
      </div>

      <h2
        class="reveal-child text-4xl md:text-6xl lg:text-[5rem] font-black text-slate-950 tracking-tighter leading-[1.05] font-heading mb-6"
      >
        Pasión por la <br class="hidden md:block" />
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-sky-500 to-[#2b3275]"
        >
          excelencia avícola.
        </span>
      </h2>
    </div>

    <div
      class="reveal relative w-full h-[75vh] min-h-137.5 rounded-[2.5rem] md:rounded-[3.5rem]
      overflow-hidden shadow-[0_40px_80px_rgba(43,50,117,0.1)] group
      opacity-0 translate-y-12 scale-[0.98] z-10"
      data-delay="150"
    >
      <div
        class="absolute inset-0 w-full h-[130%] top-[-15%] overflow-hidden bg-slate-950"
      >
        <div class="parallax-img-container w-full h-full">
          <img
            src="/nosotros/nosotros_2.webp"
            alt="Equipo Chickenbaby"
            class="w-full h-full object-cover object-center-left transition-transform duration-[2s] ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-105 opacity-90"
          />
        </div>
      </div>

      <div
        class="parallax-fast absolute bottom-18 right-4 md:top-10 md:right-10
        bg-white/10 backdrop-blur-xl border border-white/20 text-white
        w-40 h-40 rounded-full flex flex-col items-center justify-center
        shadow-2xl transition-all duration-500 hover:scale-110 hover:bg-[#2b3275]/90 hover:border-sky-400"
      >
        <span class="text-md font-black text-amber-400 text-center"
          >Progamas de Vacunas</span
        >
        <span
          class="text-[10px] md:text-xs uppercase tracking-widest text-sky-100 mt-1 font-bold text-center"
          >A necesidad del <br />Cliente</span
        >
      </div>

      <div
        class="reveal absolute z-20 left-4 sm:left-6 md:left-8 top-6 md:top-10 mx-auto w-[85%] sm:w-fit rounded-4xl p-4 md:p-6 opacity-0 -translate-x-12 translate-y-12 scale-[0.98]
        bg-slate-900/60 backdrop-blur-3xl border border-white/10 shadow-[0_30px_60px_rgba(0,0,0,0.4)] hover:bg-slate-900/70 hover:border-sky-500/30 transition-colors duration-500 group/card"
        data-delay="250"
      >
        <div class="flex items-center gap-4 md:gap-5">
          <div
            class="relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 shrink-0 rounded-[1.25rem] bg-linear-to-br from-sky-500/20 to-sky-900/40 border border-sky-500/30 shadow-[inset_0_1px_4px_rgba(255,255,255,0.2)] overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-sky-400/20 blur-xl group-hover/card:bg-sky-400/40 transition-colors duration-500"
            >
            </div>

            <svg
              class="relative z-10 w-8 h-8 md:w-10 md:h-10 text-sky-400 drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)] group-hover/card:scale-110 transition-transform duration-500"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <!-- Cintas -->
              <path
                d="M8 2L12 8L16 2"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                opacity="0.6"></path>

              <!-- Medalla -->
              <circle cx="12" cy="14" r="5" fill="currentColor" opacity="0.15"
              ></circle>

              <circle
                cx="12"
                cy="14"
                r="5"
                stroke="currentColor"
                stroke-width="1.5"></circle>

              <!-- Estrella (líder) -->
              <path
                d="M12 11.8L12.9 13.6L14.9 13.9L13.4 15.2L13.8 17.2L12 16.2L10.2 17.2L10.6 15.2L9.1 13.9L11.1 13.6L12 11.8Z"
                fill="currentColor"></path>
            </svg>
          </div>

          <div class="flex flex-col gap-0.5">
            <h4
              class="font-black text-white text-xl md:text-2xl font-heading mb-0 leading-tight drop-shadow-sm transition-colors duration-500 group-hover/card:text-amber-400"
            >
              Líderes en aves bebes
            </h4>
            <p
              class="text-slate-200 text-xs md:text-sm font-medium leading-relaxed"
            >
              La mejor calidad de aves bebes del mercado.
            </p>
          </div>
        </div>
      </div>
    </div>

    <article
      class="reveal relative z-30 mx-auto w-[92%] md:w-[80%] max-w-250
      -mt-15 md:-mt-30
      rounded-[2.5rem] md:rounded-[3rem] p-8 md:p-12
      opacity-0 translate-y-10 scale-[0.97]
      bg-slate-950/50 backdrop-blur-xl backdrop-saturate-180
      border border-white/10
      shadow-[0_30px_60px_rgba(0,0,0,0.3)]
      group overflow-hidden"
      data-delay="400"
    >
      <div
        class="absolute -inset-10 opacity-20 blur-3xl rounded-[3rem]
      bg-linear-to-br from-transparent via-sky-400/20 to-transparent
      group-hover:opacity-40 transition-opacity duration-700"
      >
      </div>

      <div class="relative z-10 grid md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-4">
          <h3
            class="reveal-child text-white text-3xl md:text-4xl font-black font-heading group-hover:text-sky-400 transition-colors duration-500"
          >
            Nuestro Propósito.
          </h3>

          <p
            class="reveal-child text-slate-200 text-sm md:text-base leading-relaxed"
          >
            Liderar el crecimiento del sector avícola mediante la producción de
            aves bebés de alta calidad genética, sanidad garantizada y máximo
            rendimiento, brindando soluciones confiables e innovadoras para el
            éxito de nuestros clientes.
          </p>
        </div>

        <div class="flex flex-col gap-6">
          <ul class="space-y-5">
            <li class="reveal-child flex items-start gap-3">
              <div
                class="mt-1 w-3.5 h-3.5 rounded-full border-[3px] border-amber-400 shrink-0"
              >
              </div>
              <p class="text-slate-200 text-sm leading-snug">
                <strong class="text-white block mb-0.5">Nuestra Misión:</strong>
                Proveer aves de excelente genética y brindar un acompañamiento técnico
                constante al productor.
              </p>
            </li>

            <li class="reveal-child flex items-start gap-3">
              <div
                class="mt-1 w-3.5 h-3.5 rounded-full border-[3px] border-sky-500 shrink-0"
              >
              </div>
              <p class="text-slate-200 text-sm leading-snug">
                <strong class="text-white block mb-0.5">Nuestra Visión:</strong>
                Ser la empresa avícola líder a nivel nacional, reconocida por nuestra
                innovación y calidad insuperable.
              </p>
            </li>
          </ul>

          <a
            href="https://api.whatsapp.com/send/?phone=%2B51949427875&text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20las%20diferentes%20lineas%20geneticas%20disponibles&type=phone_number&app_absent=0"
            target="_blank"
            class="reveal-child group/btn relative inline-flex items-center justify-center px-10 py-4 rounded-full overflow-hidden mt-2"
          >
            <div
              class="absolute inset-0 bg-white group-hover/btn:bg-sky-500 transition-colors duration-300"
            >
            </div>

            <span
              class="relative z-10 flex items-center text-slate-950 font-bold uppercase text-xs md:text-sm tracking-widest group-hover/btn:text-white transition-colors"
            >
              Contactar asesor
              <svg
                class="w-5 h-5 ml-2 transition-transform group-hover/btn:translate-x-1"
                fill="none"
                stroke="currentColor"
              >
                <path stroke-width="2.5" d="M14 5l7 7-7 7M21 12H3"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .font-heading {
    font-family: "Nunito", sans-serif;
  }

  .reveal {
    will-change: transform, opacity;
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-child {
    opacity: 0;
    transform: translateY(12px);
    transition: all 0.6s ease;
  }

  .parallax-img-container,
  .parallax-fast {
    will-change: transform;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || "0", 10);

          setTimeout(() => {
            el.classList.remove(
              "opacity-0",
              "-translate-x-12",
              "translate-y-10",
              "translate-y-12",
              "scale-[0.97]",
              "scale-[0.98]",
            );
            el.classList.add(
              "opacity-100",
              "translate-y-0",
              "translate-x-0",
              "scale-100",
            );

            const children = el.querySelectorAll<HTMLElement>(".reveal-child");
            children.forEach((child, i) => {
              setTimeout(() => {
                child.style.opacity = "1";
                child.style.transform = "translateY(0)";
              }, i * 120);
            });
          }, delay);

          obs.unobserve(el);
        });
      },
      { threshold: 0.15 },
    );

    const section = document.getElementById("acerca-section");
    if (section) {
      section.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    }

    const img = section?.querySelector(
      ".parallax-img-container",
    ) as HTMLElement | null;
    const fast = section?.querySelector(".parallax-fast") as HTMLElement | null;

    let ticking = false;

    window.addEventListener(
      "scroll",
      () => {
        if (!section) return;

        if (!ticking) {
          requestAnimationFrame(() => {
            const rect = section.getBoundingClientRect();
            const vh = window.innerHeight;

            if (rect.top < vh && rect.bottom > 0) {
              const center = rect.top + rect.height / 2;
              const distance = (center - vh / 2) / (vh / 1.5);

              if (img)
                img.style.transform = `translate3d(0, ${distance * 10}%, 0)`;
              if (fast)
                fast.style.transform = `translate3d(0, ${-distance * 50}px, 0)`;
            }

            ticking = false;
          });

          ticking = true;
        }
      },
      { passive: true },
    );
  });
</script>
