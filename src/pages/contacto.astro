---
import Layout from "../layouts/Layout.astro";
import HeroContacto from "../components/contacto/HeroContacto.astro";
import InfoContacto from "../components/contacto/InfoContacto.astro";
import FormularioContacto from "../components/contacto/FormularioContacto.astro";
---

<Layout title="Contacto - Chickenbaby">
  <!-- Componente Hero -->
  <HeroContacto />

  <section class="bg-slate-50 relative py-16" id="contacto-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Encabezado de la sección -->
      <div
        class="text-center max-w-4xl mx-auto mb-16 md:mb-20 reveal opacity-0 translate-y-10 transition-all duration-800 ease-out"
        data-delay="0"
      >
        <div class="inline-flex items-center justify-center gap-3 mb-6">
          <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
          <h3
            class="text-sky-600 font-bold tracking-[0.2em] text-xs md:text-sm uppercase"
          >
            Contacto Directo
          </h3>
          <span class="w-8 h-0.5 bg-sky-500 rounded-full"></span>
        </div>
        <h2
          class="text-4xl md:text-5xl font-black text-slate-950 tracking-tighter leading-[1.05] font-['Nunito',sans-serif] mb-4"
        >
          Escríbenos, <span
            class="text-transparent bg-clip-text bg-linear-to-r from-sky-500 to-[#2b3275]"
            >respondemos hoy.</span
          >
        </h2>
      </div>

      <!-- Tarjeta Principal (Split Layout) -->
      <article
        class="reveal relative z-30 mx-auto w-full max-w-6xl -mt-4 rounded-[2.5rem] md:rounded-[3rem] opacity-0 translate-y-12 scale-[0.98] transition-all duration-1000 ease-out bg-white shadow-[0_20px_60px_rgba(15,23,42,0.06)] border border-slate-200 flex flex-col lg:flex-row overflow-hidden"
        data-delay="150"
      >
        <!-- Izquierda: Información -->
        <InfoContacto />

        <!-- Derecha: Formulario -->
        <FormularioContacto />
      </article>
    </div>
  </section>
</Layout>

<script>
  // Lógica de animaciones Reveal
  const initReveal = () => {
    const obs = new IntersectionObserver(
      (entries, o) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || "0", 10);
          setTimeout(() => {
            el.classList.remove(
              "opacity-0",
              "translate-y-10",
              "translate-y-12",
              "scale-[0.98]",
            );
            el.classList.add("opacity-100", "translate-y-0", "scale-100");
          }, delay);
          o.unobserve(el);
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => obs.observe(el));
  };

  document.addEventListener("DOMContentLoaded", initReveal);
  document.addEventListener("astro:page-load", initReveal);
</script>
