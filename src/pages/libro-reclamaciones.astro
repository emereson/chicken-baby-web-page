---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Libro de Reclamaciones - Chickenbaby">
  <!-- ═══════════════════════════════════════
     HERO BANNER
════════════════════════════════════════ -->
  <section
    class="relative w-full h-[55vh] min-h-100 bg-slate-950 overflow-hidden select-none flex items-center justify-center"
    id="reclamos-banner"
  >
    <div
      class="absolute inset-0 w-full h-[130%] top-[-15%] pointer-events-none overflow-hidden bg-slate-950"
    >
      <!-- Cambia esta imagen por una adecuada para tu libro de reclamaciones -->
      <img
        src="/nosotros/nosotros_2.webp"
        alt="Libro de Reclamaciones Chickenbaby"
        loading="eager"
        class="parallax-bg-img w-full h-full object-cover object-center opacity-0 scale-105 will-change-transform in-[.is-loaded]:opacity-65 in-[.is-loaded]:scale-100 transition-all duration-[2s] ease-[cubic-bezier(0.16,1,0.3,1)]"
      />
    </div>

    <div
      class="absolute inset-0 bg-linear-to-b from-slate-950/80 via-slate-950/60 to-slate-950/90 z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-br from-rose-500/10 via-transparent to-orange-500/10 z-10 pointer-events-none mix-blend-overlay"
    >
    </div>

    <div class="relative z-20 w-full px-4 sm:px-6 mt-16 md:mt-10">
      <div
        id="banner-content"
        class="relative group mx-auto max-w-4xl w-full p-8 md:p-14 rounded-[3rem] text-center overflow-hidden opacity-0 translate-y-12 in-[.is-loaded]:opacity-100 in-[.is-loaded]:translate-y-0 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] delay-200 bg-slate-900/40 backdrop-blur-3xl backdrop-saturate-150 border border-white/10 shadow-[0_30px_60px_rgba(0,0,0,0.5)]"
      >
        <div
          class="absolute -inset-20 z-0 opacity-30 blur-3xl pointer-events-none rounded-[3rem] bg-linear-to-b from-rose-400/20 via-transparent to-orange-400/10 group-hover:opacity-50 transition-opacity duration-1000"
        >
        </div>

        <div class="relative z-10 flex flex-col items-center gap-5">
          <div
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 backdrop-blur-md border border-white/10 text-rose-400 text-[10px] md:text-xs font-black uppercase tracking-[0.2em] shadow-[0_4px_12px_rgba(0,0,0,0.2)]"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-orange-400 animate-pulse"
            ></span>
            Atención al Consumidor
          </div>

          <h1
            class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tighter text-white m-0 font-['Nunito',sans-serif] drop-shadow-md"
          >
            Libro de <br class="hidden sm:block" />
            <span
              class="text-transparent bg-clip-text bg-linear-to-r from-rose-400 via-orange-300 to-white"
            >
              Reclamaciones.
            </span>
          </h1>

          <p
            class="text-slate-300 text-sm md:text-lg font-medium leading-relaxed max-w-2xl mx-auto drop-shadow-sm"
          >
            Conforme a lo establecido en el Código de Protección y Defensa del
            Consumidor, contamos con un Libro de Reclamaciones a tu disposición.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
     SECCIÓN PRINCIPAL — SPLIT CARD
════════════════════════════════════════ -->
  <section class="bg-slate-50 relative py-16" id="reclamos-main">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div
        class="text-center max-w-4xl mx-auto mb-16 md:mb-20 reveal opacity-0 translate-y-10 transition-all duration-800 ease-out"
        data-delay="0"
      >
        <h2
          class="text-3xl md:text-4xl font-black text-slate-950 tracking-tighter leading-[1.05] font-['Nunito',sans-serif] mb-4"
        >
          Hoja de <span
            class="text-transparent bg-clip-text bg-linear-to-r from-rose-500 to-orange-500"
            >Reclamación virtual</span
          >
        </h2>
        <p class="text-slate-500 text-sm md:text-base">
          Tu opinión es importante para ayudarnos a mejorar nuestros servicios y
          productos.
        </p>
      </div>

      <article
        class="reveal relative z-30 mx-auto w-full max-w-6xl -mt-4 rounded-[2.5rem] md:rounded-[3rem] opacity-0 translate-y-12 scale-[0.98] transition-all duration-1000 ease-out bg-white shadow-[0_20px_60px_rgba(15,23,42,0.06)] border border-slate-200 flex flex-col lg:flex-row overflow-hidden"
        data-delay="150"
      >
        <!-- ── LADO IZQUIERDO: Panel Oscuro de Info Legal ── -->
        <div
          class="lg:w-100 xl:w-112.5 shrink-0 bg-slate-950 p-8 md:p-12 relative overflow-hidden flex flex-col justify-between"
        >
          <div
            class="absolute -left-20 -bottom-20 w-64 h-64 bg-rose-500/20 rounded-full blur-[80px] pointer-events-none"
          >
          </div>

          <div>
            <p
              class="text-[10px] font-bold text-rose-400 uppercase tracking-[0.2em] mb-8"
            >
              Información Importante
            </p>

            <div class="flex flex-col gap-6">
              <!-- Reclamo vs Queja -->
              <div
                class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/10"
              >
                <div
                  class="w-10 h-10 rounded-xl bg-orange-500/10 text-orange-400 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                  >
                </div>
                <div>
                  <span class="block text-sm font-bold text-white mb-1"
                    >Diferencias</span
                  >
                  <p class="text-xs text-slate-400 leading-relaxed mb-2">
                    <strong class="text-slate-300">Reclamo:</strong> Disconformidad
                    relacionada directamente a los productos o servicios adquiridos.
                  </p>
                  <p class="text-xs text-slate-400 leading-relaxed">
                    <strong class="text-slate-300">Queja:</strong> Malestar o descontento
                    por la atención al público brindada por nuestro personal.
                  </p>
                </div>
              </div>

              <!-- Plazo de respuesta -->
              <div
                class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/10"
              >
                <div
                  class="w-10 h-10 rounded-xl bg-rose-500/10 text-rose-400 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                  >
                </div>
                <div>
                  <span class="block text-sm font-bold text-white mb-1"
                    >Plazo de Atención</span
                  >
                  <p class="text-xs text-slate-400 leading-relaxed">
                    La formulación del reclamo no impide acudir a otras vías de
                    solución de controversias ni es requisito previo para
                    interponer una denuncia ante el INDECOPI. El proveedor
                    deberá dar respuesta al reclamo en un plazo no mayor a
                    quince (15) días hábiles.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div
            class="mt-12 lg:mt-0 relative z-10 pt-8 border-t border-white/10"
          >
            <p class="text-white text-sm font-semibold mb-1">
              Chickenbaby EIRL
            </p>
            <p class="text-slate-500 text-xs">RUC: 20614310694</p>
            <p class="text-slate-500 text-xs">Lima - Perú</p>
          </div>
        </div>

        <!-- ── LADO DERECHO: Formulario de Reclamación ── -->
        <div class="flex-1 p-8 md:p-12 bg-white relative">
          <form id="reclamacionesForm" novalidate class="flex flex-col gap-2">
            <h3
              class="text-lg font-black text-slate-800 border-b pb-2 mb-2 font-['Nunito',sans-serif]"
            >
              1. Datos del Consumidor
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="relative pb-2">
                <label
                  for="nombre"
                  class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                  >Nombre completo / Razón Social</label
                >
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all"
                />
                <span
                  class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                  id="err-nombre"></span>
              </div>

              <div class="relative pb-2">
                <label
                  for="dni"
                  class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                  >DNI / CE / RUC</label
                >
                <input
                  type="text"
                  id="dni"
                  name="dni"
                  required
                  class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all"
                />
                <span
                  class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                  id="err-dni"></span>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="relative pb-2">
                <label
                  for="telefono"
                  class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                  >Teléfono / Celular</label
                >
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  required
                  class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all"
                />
                <span
                  class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                  id="err-telefono"></span>
              </div>

              <div class="relative pb-2">
                <label
                  for="correo"
                  class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                  >Correo Electrónico</label
                >
                <input
                  type="email"
                  id="correo"
                  name="correo"
                  required
                  class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all"
                />
                <span
                  class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                  id="err-correo"></span>
              </div>
            </div>

            <div class="relative pb-2">
              <label
                for="direccion"
                class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                >Dirección completa</label
              >
              <input
                type="text"
                id="direccion"
                name="direccion"
                required
                class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all"
              />
              <span
                class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                id="err-direccion"></span>
            </div>

            <h3
              class="text-lg font-black text-slate-800 border-b pb-2 mt-4 mb-2 font-['Nunito',sans-serif]"
            >
              2. Detalle de Reclamo y/o Queja
            </h3>

            <div class="flex gap-6 mb-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="tipo"
                  value="Reclamo"
                  checked
                  class="w-4 h-4 text-rose-500 border-slate-300 focus:ring-rose-500"
                />
                <span class="text-sm font-semibold text-slate-700">Reclamo</span
                >
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="tipo"
                  value="Queja"
                  class="w-4 h-4 text-rose-500 border-slate-300 focus:ring-rose-500"
                />
                <span class="text-sm font-semibold text-slate-700">Queja</span>
              </label>
            </div>

            <div class="relative pb-2">
              <label
                for="detalle"
                class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                >Detalle del Reclamo/Queja</label
              >
              <textarea
                id="detalle"
                name="detalle"
                rows="3"
                required
                placeholder="Describe lo sucedido detalladamente..."
                class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all resize-none"
              ></textarea>
              <span
                class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                id="err-detalle"></span>
            </div>

            <div class="relative pb-2">
              <label
                for="pedido"
                class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1 mb-2 block"
                >Pedido del Consumidor</label
              >
              <textarea
                id="pedido"
                name="pedido"
                rows="2"
                required
                placeholder="¿Qué solicitas que hagamos al respecto?"
                class="w-full bg-slate-50/50 hover:bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 transition-all resize-none"
              ></textarea>
              <span
                class="absolute bottom-0 left-1 text-[11px] text-rose-500 font-medium"
                id="err-pedido"></span>
            </div>

            <!-- Checkbox Declaración Jurada (Requisito legal) -->
            <label class="flex items-start gap-3 cursor-pointer pb-4">
              <input
                type="checkbox"
                id="declaracion"
                required
                class="mt-1 w-4 h-4 text-rose-500 border-slate-300 rounded focus:ring-rose-500"
              />
              <span class="text-xs text-slate-500 leading-relaxed">
                Declaro que los datos consignados son correctos y fieles a la
                verdad. La formulación del reclamo no impide acudir a otras vías
                de solución de controversias.
              </span>
            </label>
            <span
              class="text-[11px] text-rose-500 font-medium -mt-4 mb-4 block"
              id="err-declaracion"></span>

            <button
              type="submit"
              id="submitBtnReclamo"
              class="group relative w-full flex items-center justify-center gap-3 px-8 py-4 rounded-xl overflow-hidden bg-slate-900 hover:bg-slate-800 text-white font-black uppercase text-sm tracking-widest shadow-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <span id="btnTextReclamo">Enviar Formulario</span>
              <svg
                id="btnIconReclamo"
                class="w-5 h-5 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M14 5l7 7-7 7M21 12H3"></path></svg
              >
              <svg
                id="btnSpinnerReclamo"
                class="hidden w-5 h-5 animate-spin text-white"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                ><circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle><path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path></svg
              >
            </button>
          </form>
        </div>
      </article>
    </div>
  </section>

  <!-- Componente Toast (Notificación Flotante) -->
  <div
    id="toastNotificationReclamo"
    class="fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-24 opacity-0 pointer-events-none"
  >
    <div
      id="toastIconReclamo"
      class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
    >
    </div>
    <div>
      <h4 id="toastTitleReclamo" class="text-sm font-bold text-slate-900"></h4>
      <p id="toastMsgReclamo" class="text-xs text-slate-500"></p>
    </div>
  </div>
</Layout>

<script>
  const bootReclamos = () => {
    // 1. Hero banner & Reveal animations (Reutilizado)
    const banner = document.getElementById("reclamos-banner");
    if (banner) setTimeout(() => banner.classList.add("is-loaded"), 100);

    const obs = new IntersectionObserver(
      (entries, o) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || "0", 10);
          setTimeout(() => {
            el.classList.remove(
              "opacity-0",
              "translate-y-10",
              "translate-y-12",
              "scale-[0.98]",
            );
            el.classList.add("opacity-100", "translate-y-0", "scale-100");
          }, delay);
          o.unobserve(el);
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => obs.observe(el));

    // 2. Formulario Logic
    const form = document.getElementById(
      "reclamacionesForm",
    ) as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = document.getElementById(
      "submitBtnReclamo",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btnTextReclamo");
    const btnIcon = document.getElementById("btnIconReclamo");
    const btnSpinner = document.getElementById("btnSpinnerReclamo");

    const toast = document.getElementById("toastNotificationReclamo");
    const toastTitle = document.getElementById("toastTitleReclamo");
    const toastMsg = document.getElementById("toastMsgReclamo");
    const toastIcon = document.getElementById("toastIconReclamo");

    const showToast = (
      type: "success" | "error",
      title: string,
      message: string,
    ) => {
      if (!toast || !toastTitle || !toastMsg || !toastIcon) return;
      toastTitle.textContent = title;
      toastMsg.textContent = message;
      if (type === "success") {
        toast.className =
          "fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-0 opacity-100 bg-white border border-emerald-100";
        toastIcon.className =
          "w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-emerald-100 text-emerald-500";
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>`;
      } else {
        toast.className =
          "fixed bottom-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-2xl transition-all duration-500 translate-y-0 opacity-100 bg-white border border-rose-100";
        toastIcon.className =
          "w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-rose-100 text-rose-500";
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>`;
      }
      setTimeout(() => {
        toast.classList.remove("translate-y-0", "opacity-100");
        toast.classList.add("translate-y-24", "opacity-0");
      }, 6000);
    };

    const setError = (id: string, msg: string, inputEl: HTMLElement | null) => {
      const errEl = document.getElementById(id);
      if (errEl) errEl.textContent = msg;
      if (inputEl) {
        if (msg) {
          inputEl.classList.add(
            "border-rose-500",
            "ring-4",
            "ring-rose-500/10",
          );
          inputEl.classList.remove("border-slate-200", "focus:border-rose-500");
        } else {
          inputEl.classList.remove(
            "border-rose-500",
            "ring-4",
            "ring-rose-500/10",
          );
          inputEl.classList.add("border-slate-200", "focus:border-rose-500");
        }
      }
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      let isValid = true;

      const fields = [
        "nombre",
        "dni",
        "telefono",
        "correo",
        "direccion",
        "detalle",
        "pedido",
      ];
      const formDataObj: any = {};

      fields.forEach((field) => {
        const el = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(
          `#${field}`,
        );
        if (el && !el.value.trim()) {
          setError(`err-${field}`, `Este campo es obligatorio.`, el);
          isValid = false;
        } else if (el) {
          setError(`err-${field}`, "", el);
          formDataObj[field] = el.value;
        }
      });

      const declaracion = form.querySelector<HTMLInputElement>("#declaracion");
      if (declaracion && !declaracion.checked) {
        setError(
          "err-declaracion",
          "Debe aceptar la declaración jurada.",
          null,
        );
        isValid = false;
      } else {
        setError("err-declaracion", "", null);
      }

      // Obtener el radio seleccionado
      const tipoRadio = form.querySelector<HTMLInputElement>(
        'input[name="tipo"]:checked',
      );
      formDataObj.tipo = tipoRadio ? tipoRadio.value : "Reclamo";

      if (!isValid) return;

      if (submitBtn && btnText && btnIcon && btnSpinner) {
        submitBtn.disabled = true;
        btnText.textContent = "Enviando...";
        btnIcon.classList.add("hidden");
        btnSpinner.classList.remove("hidden");
      }

      try {
        // REEMPLAZA ESTA URL CON EL ENDPOINT DE TU BACKEND PARA RECLAMACIONES
        const response = await fetch(
          "https://facturacion-cb-backend-production.up.railway.app/api/v1/apiPeru/libro-reclamaciones",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(formDataObj),
          },
        );

        if (!response.ok) throw new Error("Error en la respuesta del servidor");

        showToast(
          "success",
          "¡Formulario enviado!",
          "Su reclamo se envió correctamente y será atendido a la brevedad.",
        );
        form.reset();
      } catch (error) {
        console.error("Error:", error);
        showToast(
          "error",
          "Error al enviar",
          "Por favor, inténtelo de nuevo más tarde.",
        );
      } finally {
        if (submitBtn && btnText && btnIcon && btnSpinner) {
          submitBtn.disabled = false;
          btnText.textContent = "Enviar Formulario";
          btnIcon.classList.remove("hidden");
          btnSpinner.classList.add("hidden");
        }
      }
    });
  };

  document.addEventListener("DOMContentLoaded", bootReclamos);
  document.addEventListener("astro:page-load", bootReclamos);
</script>
